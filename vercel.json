{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/compat.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/petastral.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/compat",
      "dest": "/api/compat.py"
    },
    {
      "src": "/api/petastral",
      "dest": "/api/petastral.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
